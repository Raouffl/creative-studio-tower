# --- Database (Prisma / Postgres) ---
# Matches the local Postgres in docker-compose.dev.yaml. Start it with:
#   docker compose -f docker-compose.dev.yaml up -d
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/creative_studio?schema=public"

# --- ClickUp ---
# Personal API token: ClickUp -> Settings -> Apps -> API Token (starts with "pk_").
CLICKUP_TOKEN=""
# List to pull tasks from (Creative Studio -> Projects).
CLICKUP_LIST_ID="901517838163"
