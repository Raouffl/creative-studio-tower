# --- Database (Prisma / SQLite) ---
# Use an ABSOLUTE path to avoid the CLI-vs-runtime relative-path mismatch that
# SQLite has with Prisma. Point it at prisma/dev.db inside your checkout.
DATABASE_URL="file:/absolute/path/to/creative-studio-tower/prisma/dev.db"

# --- ClickUp ---
# Personal API token: ClickUp -> Settings -> Apps -> API Token (starts with "pk_").
CLICKUP_TOKEN=""
# List to pull tasks from (Creative Studio -> Projects).
CLICKUP_LIST_ID="901517838163"
