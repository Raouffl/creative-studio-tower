// Prisma schema — Creative Studio Tower
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Manual "revisions" (PM revision) counter per ClickUp task.
/// ClickUp doesn't natively track this on the current plan, so we persist it here.
model Revision {
  taskId    String   @id
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  USER
}

/// Dashboard login accounts. Credentials are validated in `src/auth.ts`
/// (Auth.js Credentials provider) against `passwordHash` (bcrypt). ADMINs can
/// create accounts at /admin/users; the first admin is seeded with
/// `scripts/create-user.ts` (or raw SQL).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
}
