// Prisma schema — Creative Studio Tower
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Cached PM-"revisions" count per ClickUp task, derived from the task's Figma
/// file: revisions = (number of "Version N" frames) − 1. Refreshed at most once
/// an hour (see src/lib/revisions.ts) and re-derived whenever `figmaKey` (the
/// task's current Figma file key) changes. A task with no Figma link has no row
/// here, so the board renders its revisions as "N/A".
model Revision {
  taskId    String   @id
  /// Figma file key the cached count was computed from; null = never computed.
  figmaKey  String?
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  USER
}

/// Dashboard login accounts. Credentials are validated in `src/auth.ts`
/// (Auth.js Credentials provider) against `passwordHash` (bcrypt). ADMINs can
/// create accounts at /admin/users; the first admin is seeded with
/// `scripts/create-user.ts` (or raw SQL).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
}
